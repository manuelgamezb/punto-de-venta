     
     <!DOCTYPE html>
    <html lang="es">
    <head>
    <meta charset="UTF-8">
    <title>Punto de Venta</title>
    <link rel="stylesheet" href="estilos.css">
    <script defer src="script.js"></script>
</head>
<body>

    <!--Login-->
    <div id="pantallaLogin">
        <div class="login-box">

        <!-- encabezado de login -->
    <div class="login-header">
        <h2 id="loginTitulo">Punto de Venta</h2>
        <p id="loginSubtitulo">Iniciar Sesión</p>
        </div>

        <!-- campos de login -->
         <div class="login-body">
            <label id="labelEmail">Usuario:</label>
            <input type="email" id="loginEmail" placeholder="correo@ejemplo.com">

            <label id="labelPassword">Contraseña:</label>
            <input type="password" id="loginPassword" placeholder="xxxxxxxxxx">

            <p id="loginError"></p>
            
            <button id="btnLogin">Entrar</button>

         </div>

            
    </div>
        </div>

</body>
</html>